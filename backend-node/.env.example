# =============================================
# Smart Career Advisor — Backend Environment
# Copy this file to .env and fill real values
# NEVER commit .env to Git!
# =============================================

# ── Server ─────────────────────────────────
PORT=10000
NODE_ENV=production

# ── JWT ─────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_char_hex_string_here
JWT_EXPIRES_IN=7d

# ── Frontend URL (CORS) ─────────────────────
# Set this to your Vercel / Netlify frontend URL after deploy
FRONTEND_URL=https://your-frontend.vercel.app

# ── MongoDB Atlas (Free M0 Tier) ─────────────
# Sign up: https://cloud.mongodb.com
# Create cluster → Connect → Drivers → copy SRV string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/skill_career_db?retryWrites=true&w=majority

# ── MySQL (PlanetScale / Railway / Clever Cloud) ──
# PlanetScale: https://planetscale.com  (free hobby tier)
# Railway MySQL: https://railway.app
# Clever Cloud MySQL: https://www.clever-cloud.com
MYSQL_HOST=your-mysql-host.example.com
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=skill_career_analytics
# If your provider requires SSL (PlanetScale does):
MYSQL_SSL=true

# ── Neo4j Aura (Free tier) ──────────────────
# Sign up: https://neo4j.com/cloud/platform/aura-graph-database/
# Create a free AuraDB instance → copy connection URI
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_aura_generated_password
