# =============================================
# Smart Career Advisor — .gitignore
# =============================================

# ── Node.js ──────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js

# ── Environment / Secrets ────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Frontend Build Output ────────────────────
frontend/dist/
frontend/.vite/
frontend/build/

# ── Logs ─────────────────────────────────────
*.log
logs/
frontend/frontend_debug.log
frontend/frontend_host.log

# ── OS Files ─────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── TypeScript Build ──────────────────────────
*.tsbuildinfo

# ── Python (overview/ER diagrams) ────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist-info/
.eggs/
venv/
.venv/
env/
pip-selfcheck.json

# ── Database Dumps ───────────────────────────
*.sql.gz
*.dump
*.bak

# ── Temporary Files ───────────────────────────
tmp/
temp/
.cache/
